{
  "expo": {
    "name": "Pavilion",
    "slug": "pavilion-htcc",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/pavilion-icon-1024.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/pavilion-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.htcc.pavilion",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "Pavilion does not use your camera.",
        "NSPhotoLibraryUsageDescription": "Pavilion does not access your photos.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/pavilion-icon-android.png",
        "backgroundColor": "#0D1B2A"
      },
      "package": "com.htcc.pavilion",
      "versionCode": 6,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/pavilion-icon-1024.png",
          "color": "#F5C518"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "839c48f3-c7a2-4fbd-a9c8-98e76daef60e"
      }
    },
    "owner": "nishvek10",
    "scheme": "pavilion"
  }
}